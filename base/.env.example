# Ghost stack environment configuration
# Copy to base/.env and fill in values before running docker compose
# base/.env is gitignored and must not be committed

COMPOSE_PROJECT_NAME=ghost

TZ=Europe/Madrid

# Postgres
GHOST_POSTGRES_HOST=127.0.0.1
GHOST_POSTGRES_PORT=5433
GHOST_POSTGRES_DB=ghost_core
GHOST_POSTGRES_USER=ghost
GHOST_POSTGRES_PASSWORD=

# Redis
GHOST_REDIS_PORT=6380

# n8n
GHOST_N8N_PORT=5678
GHOST_N8N_ENCRYPTION_KEY=

# LLM providers
OPENAI_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434
